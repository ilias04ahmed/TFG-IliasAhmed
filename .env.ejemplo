# Plantilla de la configuración que he usado realmente en mi archivo .env para no exponer las contraseñas y URLS con las que trabajo
DATABASE_HOST=localhost
DATABASE_NAME=base_datos
DATABASE_USER=usuario
DATABASE_PASSWORD=contraseña

# Configuración que iría en el entorno local de la Raspberry Pi
URL_NGROK=https://tu-subdominio-ngrok.dev/api/gps
VEHICULO_ID=L1
RUTA_ID=L1
PUERTO_SERIAL=/dev/serial0
BAUD_RATE=9600